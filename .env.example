# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-api-key

# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://your-resource.aiinfused.com
AZURE_AI_FOUNDRY_KEY=your-api-key

# Entra ID (for OAuth2 client credentials)
AZURE_ENTRA_TENANT_ID=your-tenant-id
AZURE_ENTRA_CLIENT_ID=your-client-id
AZURE_ENTRA_CLIENT_SECRET=your-client-secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_gateway

# PAT Secret (for HMAC-SHA256 signing)
PAT_SECRET=your-secret-at-least-32-characters-long

# Optional /admin second factor (header: X-Operator-Secret)
# ADMIN_OPERATOR_SECRET=your-operator-secret-at-least-16-characters

# OpenTelemetry
OTEL_EXPORTER_OTLP_GRPC_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llm-gateway
OTEL_ENABLED=true
OTEL_TRACING_SAMPLER_RATIO=0.1

# Rate limiting defaults
RATE_LIMIT_RPM=100
RATE_LIMIT_TPM=100000

# Quota defaults
QUOTA_RESERVATION_TTL_SECONDS=300
QUOTA_MULTIPLIER=1.2

# Write-Ahead-Log replayer
# WAL_DIR=/var/lib/llm-gateway/dlq
# WAL_REPLAY_INTERVAL_MS=60000

# Interactive API documentation. Off by default; set to 'true' to expose
# /openapi.json and /docs (Scalar UI).
# DOCS_ENABLED=false
