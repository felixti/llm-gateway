{
  "name": "llm-gateway",
  "version": "1.0.0",
  "description": "LLM Gateway API proxy server for Azure OpenAI and Azure AI Foundry",
  "type": "module",
  "runtime": "bun",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "setup:local": "bash scripts/run-local.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "test:curl": "bash scripts/curl-tests.sh",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:coverage": "bun test --coverage",
    "test:coverage:check": "bun test --coverage --coverage-threshold=90",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "ci": "bun run lint && bun run typecheck && bun run test:coverage:check",
    "load:test": "k6 run tests/load/k6.config.ts",
    "load:test:quota": "k6 run tests/load/quota-pressure.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@scalar/hono-api-reference": "^0.10.13",
    "decimal.js": "^10.4.3",
    "hono": "^4.0.0",
    "hono-compress": "^1.0.2",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "postgres": "^3.4.3",
    "tiktoken": "^1.0.13",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.0.0",
    "@types/uuid": "^9.0.7",
    "testcontainers": "^10.9.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
